# Local Windows .env template — copy to repo-root .env (gitignored)
#
# Sections: Azure DI (production parity) | Azure CV (Local Enhanced) |
#           Content Understanding (optional check leg) | Postgres | App identity
#
# Never commit keys, client data, or cache artifacts.

# --- Azure Document Intelligence (Bank Statements production path) ---
# Portal → Document Intelligence resource → Keys and Endpoint
# AZURE_DI_ENDPOINT=https://your-di-resource.cognitiveservices.azure.com/
# AZURE_DI_KEY=your-primary-key-here
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=
# Optional model overrides (App Service defaults via Set-AzureBankStatementDIAppSettings.ps1)
# AZURE_DI_MODEL=prebuilt-bankStatement.us
# AZURE_DI_CHECK_MODEL=prebuilt-check.us
# AZURE_DI_TIMEOUT_SEC=180

# --- Azure Computer Vision Read (Local Enhanced OCR / hybrid check leg only) ---
# Replace BOTH lines with real values from Azure Portal → CV resource → Keys and Endpoint.
# Placeholder text is ignored (pipeline falls back to EasyOCR on crops).
# AZURE_CV_ENDPOINT=https://your-cv-resource.cognitiveservices.azure.com/
# AZURE_CV_KEY=your-primary-key-here
AZURE_CV_ENDPOINT=
AZURE_CV_KEY=

# Imaging pages (Traditions hard PDF: pages 5–9)
SLAM_IMAGING_FIRST_PAGE=5
# Optional last page bound (blank = through end of statement)
SLAM_IMAGING_LAST_PAGE=9

# Strongly recommended for dev — zero cost, zero rate limits (reuses Phase-1 CV JSON)
# SLAM_CV_CACHE_DIR=Scripts/spike/artifacts/phase1_real_cv_read_harness_20260526T195813Z__rescored/raw_cv_responses

# Helps bank profile selection for payee scoring (Local Enhanced / payee_extractor)
# SLAM_CLIENT_NAME=Auto Body Center

# Optional legacy gate for production App Service (not required for Local Enhanced)
# SLAM_HYBRID_CV_ENABLED=true

# --- Azure Content Understanding (optional check leg; Foundry project URL) ---
# Used when CU credentials are set; otherwise DI check model is used.
# CONTENTUNDERSTANDING_ENDPOINT=https://your-resource.services.ai.azure.com
# CONTENTUNDERSTANDING_KEY=your-key-here
# CONTENTUNDERSTANDING_CHECK_ANALYZER=prebuilt-check.us
# AZURE_CU_TIMEOUT_SEC=180

# --- PostgreSQL (local round-trip or Azure Postgres dev) ---
# USE_POSTGRES=false
# DATABASE_URL=postgresql://user:pass@localhost:5432/slam_revenue
# Or discrete vars: POSTGRES_HOST, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB
# POSTGRES_SSLMODE=require

# --- App identity (local dev) ---
# SLAM_APP_USER=Robert

# Local Enhanced only: payee_extractor needs PyYAML (pip install PyYAML).
# Not required for Azure DI production — install via Install-LocalHeavyOcr.ps1 or manually.
