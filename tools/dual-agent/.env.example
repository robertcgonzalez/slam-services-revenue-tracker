# ============================================
# Dual-Agent Configuration
# Copy this file to .env and fill in your values
# ============================================

# === REQUIRED: Cursor API Key ===
# Get this from: https://cursor.com/dashboard/integrations
# (User API key or Team service account key)
CURSOR_API_KEY=cur_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === OPTIONAL: Model selection for Cursor side ===
# Common options: composer-2.5, auto, gpt-4.1, claude-3.5-sonnet, etc.
# Leave empty to use Cursor's default for the SDK.
CURSOR_MODEL=composer-2.5

# === OPTIONAL: Grok model (passed via -m flag) ===
# Examples: grok-build, grok-3, grok-4 (whatever you have access to)
GROK_MODEL=grok-build

# === Collaboration behavior ===
# Max number of back-and-forth turns between the two agents
MAX_TURNS=8

# Whether to auto-approve all actions on both sides (use with caution)
# YOLO_GROK=true
# YOLO_CURSOR=true

# === Advanced ===
# Working directory for both agents (defaults to current dir)
# WORK_DIR=.

# Session storage location (for resuming long collaborations)
# SESSIONS_DIR=./.dual-agent-sessions
