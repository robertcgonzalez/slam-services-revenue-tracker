# SLAM Services Project .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE / Editor
.idea/
*.swp
*.swo
*~

# Allow sharing of key VS Code / Cursor workspace configs
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.md
!.cursor/rules/
!.cursor/rules/**

# OS
.DS_Store
Thumbs.db

# Azure / Deployment artifacts (keep source only)
*.log
deployment_diagnose.log
logextract/
*.zip
__pycache__/

# Client financial / PII data – NEVER commit to any repo
**/*.csv
**/*.xlsx
**/*.xls
Data/
Data/**

# Secrets / Local config
.env
*.env
secrets/
*.pem
*.key

# Kilo / temporary AI workspaces
.kilocode/
.kilo/

# Continue.dev (unused — Cursor + Kilo Code only)
.continue/

# Node (if any future tooling)
node_modules/

# Local editor backups
*.bak
