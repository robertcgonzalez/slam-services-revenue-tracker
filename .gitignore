# SLAM Services — Security-First .gitignore

# ==================== Client Data & Sensitive Files ====================
Data/
**/*.csv
**/*.xlsx
**/*.xls
feedback_log.csv
*.env
.secrets/
secrets/
*.pem
*.key
*.pfx
*.p12

# ==================== Secrets & Credentials ====================
# Never commit passwords, API keys, tokens, or config with secrets
SLAM_APP_PASSWORD
.secret
config.json
credentials*.*
*.log
deployment_diagnose.log
logextract/

# ==================== Generated / Large / Report Files ====================
# Large or auto-generated reports (do not commit to keep repo clean)
Project-Structure-Report.txt
*.report.txt
*structure-report*
*-report.txt
*.large.*
*.backup.*

# ==================== Development Artifacts ====================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# Build & Deploy
*.zip
*.tar.gz
dist/
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
*.so
startup.sh.bak

# IDE & Tooling temp
.idea/
.vscode/.history/
.vscode/*.code-workspace
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.kilo/
.kilocode/
.continue/
*.bak
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Node (future tooling)
node_modules/

# ==================== Allowed (explicitly not ignored) ====================
# .vscode/ workspace configs are intentionally committed (shared team settings)
!.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.md

# Cursor rules (committed; rest of .cursor/ ignored above)
!.cursor/rules/
!.cursor/rules/**
